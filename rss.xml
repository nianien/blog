  <item>
    <title>Redis 核心机制与工程实践：从数据结构选型到持久化的设计权衡</title>
    <link>https://www.skyfalling.cn/blog/engineering/middleware/Redis%E6%A0%B8%E5%BF%83%E6%9C%BA%E5%88%B6%E4%B8%8E%E5%B7%A5%E7%A8%8B%E5%AE%9E%E8%B7%B5%EF%BC%9A%E4%BB%8E%E6%95%B0%E6%8D%AE%E7%BB%93%E6%9E%84%E9%80%89%E5%9E%8B%E5%88%B0%E6%8C%81%E4%B9%85%E5%8C%96%E7%9A%84%E8%AE%BE%E8%AE%A1%E6%9D%83%E8%A1%A1/</link>
